#!/bin/bash

if command -v tmux >/dev/null 2>&1; then
  if [ -z "$TMUX" ] && [ -z "$SSH_CONNECTION" ] && [ "$TERM" != "linux" ] && [ "$TERM" != "vt100" ]; then
    sessions=($(tmux list-sessions -F '#S' 2>/dev/null))
    session_count=${#sessions[@]}
    if [ "$session_count" -eq 0 ]; then
      exec tmux new-session -s s-0
    fi
    echo "Available tmux sessions:"
    for i in "${!sessions[@]}"; do
      printf "[%d] %s\n" "$i" "${sessions[$i]}"
    done
    echo "[n] New session"
    echo "[q] Quit"
    echo -n "Select session number, 'n' for new, or 'q' to quit: "
    read -n 1 selection
    echo
    if [ "$selection" = "q" ]; then
      echo "Quitting tmux launcher."
      exit 0
    elif [ "$selection" = "n" ]; then
      next=0
      while tmux has-session -t "s-$next" 2>/dev/null; do
        next=$((next + 1))
      done
      exec tmux new-session -s "s-$next"
    elif [[ "$selection" =~ ^[0-9]$ ]] && [ "$selection" -lt "$session_count" ]; then
      exec tmux attach-session -t "${sessions[$selection]}"
    else
      echo "Invalid selection."
    fi
  fi
fi
